# Groq API Key — get yours free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Model configuration
# Orchestrator: strong reasoning model for planning & tool selection
ORCHESTRATOR_MODEL=llama-3.3-70b-versatile
# Explore Agent: fast model for execution-heavy multi-file investigations
EXPLORE_MODEL=llama-3.1-8b-instant
# Compactor: fast model for history summarization
COMPACTOR_MODEL=llama-3.1-8b-instant

# Context management
# Fraction of context window at which the compactor triggers (0.0 - 1.0)
CONTEXT_THRESHOLD=0.70
# Orchestrator model context window size in tokens (llama-3.3-70b-versatile = 128k)
ORCHESTRATOR_CONTEXT_WINDOW=128000

# Default repository path (can be overridden per-request)
REPO_PATH=.

# API server
HOST=0.0.0.0
PORT=8000
