# Anthropic API Key (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model configuration
ORCHESTRATOR_MODEL=claude-3-7-sonnet-20250219
EXPLORE_MODEL=claude-3-5-haiku-20241022
COMPACTOR_MODEL=claude-3-5-haiku-20241022

# Context management
# Fraction of context window at which the compactor triggers (0.0 - 1.0)
CONTEXT_THRESHOLD=0.70
# Orchestrator model context window size in tokens
ORCHESTRATOR_CONTEXT_WINDOW=200000

# Default repository path (can be overridden per-request)
REPO_PATH=.

# API server
HOST=0.0.0.0
PORT=8000
